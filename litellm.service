[Unit]
Description=LiteLLM Proxy Server
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=matt
WorkingDirectory=/home/matt/.openclaw
EnvironmentFile=/home/matt/.openclaw/.env
ExecStart=/home/matt/.local/bin/litellm --config litellm-config.yaml --port 8766 --host 127.0.0.1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
